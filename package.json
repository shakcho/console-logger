{
  "name": "konsole-logger",
  "version": "4.3.0",
  "type": "module",
  "description": "Structured, namespaced logging for browser and Node.js — numeric log levels, child loggers, beautiful terminal output, flexible transports",
  "main": "./dist/konsole.umd.cjs",
  "module": "./dist/konsole.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/konsole.js",
        "require": "./dist/konsole.umd.cjs"
      },
      "browser": {
        "import": "./dist/konsole.js",
        "require": "./dist/konsole.umd.cjs"
      },
      "import": "./dist/konsole.js",
      "require": "./dist/konsole.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "benchmark": "node benchmarks/throughput.mjs",
    "benchmark:gc": "node --expose-gc benchmarks/throughput.mjs",
    "benchmark:size": "node benchmarks/size.mjs",
    "site:install": "npm install --prefix site",
    "site:dev": "npm run --prefix site dev",
    "site:build": "npm run --prefix site build"
  },
  "keywords": [
    "logger",
    "logging",
    "console",
    "debug",
    "typescript",
    "namespaced-logging",
    "structured-logging",
    "browser",
    "node",
    "pino",
    "pino-compatible",
    "pino-alternative",
    "ndjson",
    "child-logger"
  ],
  "author": "Sakti Kumar Chourasia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakcho/console-logger.git"
  },
  "bugs": {
    "url": "https://github.com/shakcho/console-logger/issues"
  },
  "homepage": "https://github.com/shakcho/console-logger",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^4.3.0",
    "vitepress": "^1.5.0",
    "vitest": "^3.2.4"
  }
}
